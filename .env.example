# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Arbitrary secret string — used to verify that webhooks come from Telegram
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

# ─── Google Drive ──────────────────────────────────────────────────────────
# Full JSON key of your Service Account (paste as a single line, no line breaks)
# Get from: Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"collector-bot@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ID of the root Google Drive folder shared with the Service Account
# Get from the folder URL: https://drive.google.com/drive/folders/THIS_IS_THE_ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs

# ─── Database (Railway PostgreSQL) ────────────────────────────────
# Get from Railway project → PostgreSQL → Variables → DATABASE_URL
DATABASE_URL=postgresql://postgres:password@containers-us-west-1.railway.app:5432/railway

# ─── Yandex SpeechKit ───────────────────────────────────────────────
# Get from Yandex Cloud Console → Service Accounts → API Keys
YANDEX_CLOUD_API_KEY=AQVN...
# Your Yandex Cloud folder ID (from the console URL)
YANDEX_CLOUD_FOLDER_ID=b1g...

# ─── NextAuth / Web Dashboard ─────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your_nextauth_secret_here
# Your deployment URL
NEXTAUTH_URL=https://your-app.vercel.app

# Google OAuth credentials for web login (separate from Google Drive service account)
# Get from: Google Cloud Console → APIs → Credentials → OAuth 2.0 Client IDs
GOOGLE_OAUTH_CLIENT_ID=1234567890-xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxx

# ─── Application ──────────────────────────────────────────────────────────
# Your deployment URL (Vercel or ngrok for local dev)
# Used to register the Telegram webhook
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
