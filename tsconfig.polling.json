{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "scripts/polling.ts",
    "src/services/bot.ts",
    "src/services/google-drive.ts",
    "src/services/user-service.ts",
    "src/services/upload-service.ts",
    "src/services/yandex-speechkit.ts",
    "src/lib/env.ts",
    "src/lib/helpers.ts",
    "src/db/index.ts",
    "src/db/schema.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
